APP_NAME="LMS Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=lms_db
DB_USERNAME=lms_user
DB_PASSWORD=lms_password

# ── Session / Cache / Queue ───────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── MinIO (S3-compatible) ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=lms-videos
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# ── MongoDB (chat history) ────────────────────────────────────────────────────
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=lms_chat

# ── Google OAuth (SSO) ────────────────────────────────────────────────────────
#GOOGLE_CLIENT_ID=your-google-client-id
#GOOGLE_CLIENT_SECRET=your-google-client-secret
#GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@lms.local"
MAIL_FROM_NAME="${APP_NAME}"

# ── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8001
OPENAI_API_KEY=

# ── PayOS ─────────────────────────────────────────────────────────────────────
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=http://localhost/payment/payos/callback
PAYOS_CANCEL_URL=http://localhost/payment/payos/callback?cancelled=1
PAYOS_WEBHOOK_URL=http://localhost/api/payos/webhook
